# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=production
FLASK_SECRET_KEY=generate-a-secure-random-key-here

# JWT Configuration
JWT_SECRET_KEY=generate-another-secure-random-key-here
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7

# Database Configuration
# Local SQLite default
DATABASE_PATH=lostnfound.db
# Production PostgreSQL/Supabase URI
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:user@db.supabase.com:5432/postgres

# Email Configuration (SMTP)
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=onboarding@yourdomain.com

# Security
# Set to 'true' in production with HTTPS
JWT_COOKIE_SECURE=false
JWT_COOKIE_CSRF_PROTECT=false
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7

# Absolute session timeout (in hours)
SESSION_ABSOLUTE_TIMEOUT_HOURS=24

# CORS Configuration
# Comma-separated list of origins, or '*' for all
CORS_ORIGINS=*

# Password Reset
RESET_TOKEN_EXPIRY_MINUTES=60
